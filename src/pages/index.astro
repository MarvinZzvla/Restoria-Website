---
import { sitePath, absoluteUrl } from '../lib/assets';

const esPath = sitePath('es/');
const enPath = sitePath('en/');
const canonicalEs = absoluteUrl('es/');
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Resoria</title>
    <script is:inline define:vars={{ esPath, enPath }}>
      (function () {
        var lang = (navigator.language || navigator.userLanguage || '').toLowerCase();
        var target = lang.indexOf('en') === 0 ? enPath : esPath;
        location.replace(target);
      })();
    </script>
    <meta http-equiv="refresh" content={`0;url=${esPath}`} />
    <link rel="canonical" href={canonicalEs} />
    <meta name="robots" content="noindex" />
  </head>
  <body></body>
</html>
